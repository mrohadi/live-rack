# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/liverack?sslmode=disable

# NATS
NATS_URL=nats://localhost:4222

# ClickHouse
CLICKHOUSE_URL=http://liverack:liverack@localhost:8123
CLICKHOUSE_DB=liverack

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=live-rack

# Zitadel Dev (for OIDC authentication)
OIDC_PROJECT_ID=375294302823120905
VITE_OIDC_CLIENT_ID=375295100143599625
# Service-account token (PAT) authorizing onboarding: org/user creation + role
# grants (LR-907 invite, LR-908 signup). Grant the SA ORG_OWNER / USER_MANAGER.
ZITADEL_MGMT_TOKEN=

# Custom login UI (LR-909): token for Zitadel Session API + auth-request finalize.
# Service user needs IAM_LOGIN_CLIENT. Falls back to ZITADEL_MGMT_TOKEN if unset.
ZITADEL_LOGIN_CLIENT_TOKEN=

# SPA origin used in invite-email links (custom /verify-email screen, LR-909).
APP_BASE_URL=http://localhost:5173

