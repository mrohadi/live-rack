# live-rack production env — copy to .env.prod on the Lightsail host
# Mode 600, owner ec2-user. Never commit.
#
#   scp .env.prod.example ec2-user@HOST:~/live-rack/.env.prod
#   ssh ec2-user@HOST 'chmod 600 ~/live-rack/.env.prod'
#   ssh in, fill secrets, then `docker compose ... up -d`

# ── Public reachability ──────────────────────────────────────────────────────
PUBLIC_DOMAIN=live-rack.mrohadi.com

# ── Container registry ───────────────────────────────────────────────────────
# Lowercase GitHub username/org owning the GHCR images
GHCR_OWNER=mrohadi
# Image tag the host pulls. CI bumps this to commit SHA on deploy.
IMAGE_TAG=latest

# ── Postgres (live-rack owned) ───────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_32_CHAR_RANDOM
# DATABASE_URL constructed inside docker-compose.prod.yml from POSTGRES_PASSWORD.
# Single source of truth — no drift between the two values.

# ── Redis (reused from existing infra-redis-1) ───────────────────────────────
# Reach existing infra-redis-1 by container name on the shared `caddy` network.
# infra-redis-1 must be added to caddy network if not already:
#   docker network connect caddy infra-redis-1
REDIS_URL=redis://infra-redis-1:6379
# Key prefix avoids collision with other apps on the shared Redis
REDIS_PREFIX=liverack:

# ── Object storage (MinIO) ───────────────────────────────────────────────────
S3_ACCESS_KEY=liverack
S3_SECRET_KEY=CHANGE_ME_MIN_8_CHARS

# ── OIDC (frontend + backend) ────────────────────────────────────────────────
OIDC_ISSUER=https://live-rack.mrohadi.com
# Fill after first Zitadel boot — Console > Projects > live-rack > Resource ID
OIDC_PROJECT_ID=
# Fill after first Zitadel boot — Console > Projects > live-rack > Applications > web > Client ID
VITE_OIDC_CLIENT_ID=
VITE_OIDC_ISSUER=https://live-rack.mrohadi.com
VITE_OIDC_REDIRECT_URI=https://live-rack.mrohadi.com/callback
# API origin only — the SPA appends /api/v1/... itself (lib/api.ts, useLogin.ts).
# Build-time arg baked into the web image; also stored as the GitHub secret
# VITE_API_URL used by the deploy workflow.
VITE_API_URL=https://live-rack.mrohadi.com

# ── Zitadel admin bootstrap ──────────────────────────────────────────────────
ZITADEL_MASTERKEY=CHANGE_ME_EXACTLY_32_CHARACTERS_
ZITADEL_DB_PASSWORD=CHANGE_ME_32_CHAR_RANDOM
ZITADEL_ADMIN_EMAIL=you@mrohadi.com
ZITADEL_ADMIN_PASSWORD=CHANGE_ME_strong_passphrase!

# ── Zitadel service tokens (onboarding + custom login) ───────────────────────
# Required for self-service signup (POST /api/v1/signup) and the custom /login
# Session API. Mint a service-user PAT after first Zitadel boot:
#   Console > Users > Service Users > New > generate Personal Access Token,
#   then grant it Manager role IAM_OWNER (Instance) so it can create orgs/users.
ZITADEL_MGMT_TOKEN=CHANGE_ME_service_account_pat
# Optional: dedicated IAM_LOGIN_CLIENT token for the Session API. Leave blank to
# reuse ZITADEL_MGMT_TOKEN (IAM_OWNER is a superset).
ZITADEL_LOGIN_CLIENT_TOKEN=

# ── SMTP (Zitadel verification + password reset emails) ──────────────────────
# Pick one provider, fill creds. Free tiers:
#   - Resend:   smtp.resend.com:587, user=resend, pass=re_xxxx  (3k mails/mo)
#   - Brevo:    smtp-relay.brevo.com:587, user=login@..., pass=smtp-key  (300/day)
#   - SES:      email-smtp.<region>.amazonaws.com:587  (cheap, requires verify)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_CHANGE_ME
SMTP_TLS=true
SMTP_FROM=noreply@mrohadi.com
