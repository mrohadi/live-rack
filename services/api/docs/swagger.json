{
    "swagger": "2.0",
    "info": {
        "description": "Warehouse zoning, scanning, and analytics API.",
        "title": "live-rack API",
        "contact": {},
        "version": "0.1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/stores/{storeID}/scan/validate": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "scans"
                ],
                "summary": "Validate a scan against zone rules",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store UUID",
                        "name": "storeID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Scan body",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/scans.validateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/scans.ValidateResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/scans.ValidateResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/scans.ValidateResponse"
                        }
                    }
                }
            }
        },
        "/stores/{storeID}/zones": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "zones"
                ],
                "summary": "List zones by store",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store UUID",
                        "name": "storeID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/zones.ZoneResponse"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "zones"
                ],
                "summary": "Create a zone",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store UUID",
                        "name": "storeID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Zone body",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/zones.zoneRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/zones.ZoneResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/stores/{storeID}/zones/{id}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "zones"
                ],
                "summary": "Get a zone by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store UUID",
                        "name": "storeID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Zone UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/zones.ZoneResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    }
                }
            },
            "put": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "zones"
                ],
                "summary": "Update a zone",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store UUID",
                        "name": "storeID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Zone UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Zone body",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/zones.zoneRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/zones.ZoneResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "zones"
                ],
                "summary": "Delete a zone",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store UUID",
                        "name": "storeID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Zone UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/zones.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "scans.ValidateResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                },
                "requires_dual_scan": {
                    "type": "boolean"
                },
                "valid": {
                    "type": "boolean"
                }
            }
        },
        "scans.validateRequest": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "current_qty": {
                    "type": "integer"
                },
                "dual_scan_confirmed": {
                    "type": "boolean"
                },
                "last_scan_at": {
                    "description": "TODO LR-205: source from scan_events server-side",
                    "type": "string"
                },
                "scan_qty": {
                    "type": "integer"
                },
                "zone_id": {
                    "type": "string"
                }
            }
        },
        "zones.ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "zone not found"
                }
            }
        },
        "zones.ZoneResponse": {
            "type": "object",
            "properties": {
                "capacity": {
                    "type": "integer",
                    "example": 50
                },
                "color": {
                    "type": "string",
                    "example": "#6366f1"
                },
                "constraints": {
                    "type": "object"
                },
                "created_at": {
                    "type": "string"
                },
                "height": {
                    "type": "number",
                    "example": 80
                },
                "id": {
                    "type": "string",
                    "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
                },
                "name": {
                    "type": "string",
                    "example": "Zone A"
                },
                "org_id": {
                    "type": "string"
                },
                "store_id": {
                    "type": "string"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "general",
                        "frozen",
                        "returns",
                        "staging",
                        "display",
                        "checkout"
                    ],
                    "example": "general"
                },
                "updated_at": {
                    "type": "string"
                },
                "width": {
                    "type": "number",
                    "example": 100
                },
                "x": {
                    "type": "number",
                    "example": 10
                },
                "y": {
                    "type": "number",
                    "example": 20
                }
            }
        },
        "zones.zoneRequest": {
            "type": "object"
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}